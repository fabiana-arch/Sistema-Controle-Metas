# ============================================
# Variáveis de Ambiente - Sistema de Metas
# ============================================
# Copie este arquivo para .env e preencha os valores

# URL de conexão com o banco de dados PostgreSQL
# Formato: postgres://usuario:senha@host:porta/nome_banco
DATABASE_URL=postgres://username:password@localhost:5432/sistema_metas

# Chave secreta para geração de tokens JWT (use uma string aleatória e longa)
JWT_SECRET=troque_por_uma_chave_secreta_muito_longa_e_aleatoria_aqui

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente de execução: development | production
NODE_ENV=development
