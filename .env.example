# Porta HTTP (local). Em Render, o PORT vem do painel — não precisa definir.
PORT=3000

# Obrigatório em produção: string longa e aleatória para assinar os tokens JWT.
JWT_SECRET=altere_para_um_segredo_longo_e_unico

# --- Banco de dados (use UM dos modos) ---

# Modo nuvem (Render, Railway, etc.): cole a connection string do PostgreSQL.
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Opcional: desativar SSL ao ligar ao Postgres local sem TLS.
# PGSSLMODE=disable

# Modo local sem Postgres: não defina DATABASE_URL. O app usa SQLite em:
# ./data/app.db (ou o caminho em SQLITE_PATH)
# SQLITE_PATH=./data/app.db
