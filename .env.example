# Database URL (PostgreSQL online, por exemplo Neon/Supabase/Render/Railway)
DATABASE_URL=postgres://username:password@host:5432/database_name

# Use "true" quando o provedor exigir SSL
DATABASE_SSL=true

# Segurança do token JWT
JWT_SECRET=troque_este_segredo_por_um_valor_forte
JWT_EXPIRES_IN=7d

# Porta do servidor
PORT=3000

# URL do frontend (domínio publicado)
# Para múltiplos domínios, separe por vírgula:
# FRONTEND_ORIGIN=https://app.exemplo.com,https://admin.exemplo.com
FRONTEND_ORIGIN=http://localhost:3000
