# Porta HTTP da aplicacao
PORT=3000

# Troque por um segredo forte em producao
JWT_SECRET=troque-por-um-segredo-forte

# Opcional: use um PostgreSQL online para persistencia profissional
# Exemplo: postgres://usuario:senha@host:5432/banco
DATABASE_URL=

# Ative como true em bancos gerenciados que exigem SSL
DATABASE_SSL=false

# Opcional: caminho do arquivo local usado quando DATABASE_URL estiver vazio
STORAGE_FILE=./data/app.json
